# Copy this to .env.local for local development. Do NOT commit .env.local.
# For Vercel: add each variable in Project → Settings → Environment Variables.

# ----- MongoDB (server-only) -----
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net
MONGODB_DB_NAME=your_database_name

# ----- Firebase Client (exposed to browser; required for auth UI) -----
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id

# ----- Firebase Admin (server-only; for API auth) -----
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Paste the private key as a single line with \n for newlines, or in Vercel paste with real newlines.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ----- Gemini (server-only; optional for AI chat) -----
GEMINI_API_KEY=your_gemini_api_key
